{
  "name": "pkgxray",
  "version": "0.13.2",
  "description": "Zero-dep local CLI and MCP server that scans npm packages for supply-chain risk. OSV vuln pre-check, sandboxed quarantine, tarball-integrity verification, calibrated static heuristics, GitHub provenance cross-check.",
  "license": "MIT",
  "author": "Jack Adams-Lovell",
  "type": "commonjs",
  "bin": {
    "pkgxray": "./bin/audit.js",
    "pkgxray-mcp": "./bin/mcp-server.js",
    "pkgxray-cache": "./bin/pkgxray-cache.js"
  },
  "files": [
    "bin/",
    "src/",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build:browser": "node ./scripts/build-browser-extension.js",
    "test": "node --test",
    "audit:evidence": "node ./bin/audit.js",
    "mcp": "node ./bin/mcp-server.js",
    "cache": "node ./bin/pkgxray-cache.js"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/adamsjack711-ux/pkgxray.git"
  },
  "homepage": "https://github.com/adamsjack711-ux/pkgxray#readme",
  "bugs": {
    "url": "https://github.com/adamsjack711-ux/pkgxray/issues"
  },
  "keywords": [
    "mcp",
    "security",
    "supply-chain",
    "npm-audit",
    "agent-extension"
  ],
  "engines": {
    "node": ">=18"
  }
}
